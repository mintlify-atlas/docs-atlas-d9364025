  "keyFeatures": [
    "Framework-agnostic: works with Next.js, Nuxt, SvelteKit, Hono, Express, Expo, and more",
    "Comprehensive plugin ecosystem: 2FA, passkey, organization, SSO, OIDC, magic link, and more",
    "Multiple database adapters: Drizzle, Prisma, MongoDB, SQLite, PostgreSQL, MySQL",
    "Built-in social OAuth providers: Google, GitHub, Apple, Discord, and 30+ more",
    "Type-safe client SDK for React, Vue, Svelte, Solid, and vanilla JS",
    "CLI tool for schema generation and database migration",
    "Enterprise features: multi-tenant organizations, SCIM provisioning, SAML SSO",
    "MCP server support for AI assistant integrations"
  ],
  "publicApiSurface": [
    "betterAuth(config) — core auth instance factory",
    "createAuthClient(config) — type-safe client SDK factory",
    "betterAuth/react — React hooks (useSession, etc.)",
    "betterAuth/vue — Vue composables",
    "betterAuth/svelte — Svelte stores",
    "betterAuth/plugins — built-in plugin exports (twoFactor, organization, admin, jwt, etc.)",
    "betterAuth/adapters/drizzle — Drizzle ORM adapter",
    "betterAuth/adapters/prisma — Prisma ORM adapter",
    "betterAuth/adapters/mongodb — MongoDB adapter",
    "betterAuth/next-js — Next.js route handler helper",
    "betterAuth/node — Node.js handler helper",
    "betterAuth/svelte-kit — SvelteKit handler helper",
    "npx auth generate — CLI schema generation",
    "npx auth migrate — CLI database migration"
  ]
}
